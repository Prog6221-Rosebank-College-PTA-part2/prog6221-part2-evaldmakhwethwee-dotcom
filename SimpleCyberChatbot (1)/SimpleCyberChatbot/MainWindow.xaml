<Window x:Class="SimpleCyberChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Chatbot"
        Height="620"
        Width="850"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Background="#F4F7FB">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Simple header with ASCII art translated into GUI -->
        <Border Grid.Row="0" Background="#23395D" CornerRadius="12" Padding="14" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Cybersecurity Awareness Chatbot"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           TextAlignment="Center" />

                <TextBlock Foreground="#D6E9FF"
                           FontFamily="Consolas"
                           FontSize="13"
                           TextAlignment="Center"
                           Margin="0,10,0,0"
                           Text="   ____      _                 ____        _&#x0a;  / ___|   _| |__   ___ _ __  | __ )  ___ | |_&#x0a; | |  | | | | '_ \ / _ \ '__| |  _ \ / _ \| __|&#x0a; | |__| |_| | |_) |  __/ |    | |_) | (_) | |_&#x0a;  \____\__, |_.__/ \___|_|    |____/ \___/ \__|&#x0a;       |___/" />
            </StackPanel>
        </Border>

        <!-- Chat display area -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="10" BorderBrush="#D0D7DE" BorderThickness="1">
            <ScrollViewer x:Name="ChatScroll" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ChatPanel" />
            </ScrollViewer>
        </Border>

        <!-- Input area -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="110" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="UserInput"
                     Grid.Column="0"
                     Height="44"
                     FontSize="15"
                     Padding="10"
                     VerticalContentAlignment="Center"
                     KeyDown="UserInput_KeyDown" />

            <Button Grid.Column="1"
                    Content="Send"
                    Height="44"
                    FontSize="15"
                    FontWeight="Bold"
                    Foreground="White"
                    Background="#23395D"
                    Margin="10,0,0,0"
                    Click="SendButton_Click" />
        </Grid>
    </Grid>
</Window>
