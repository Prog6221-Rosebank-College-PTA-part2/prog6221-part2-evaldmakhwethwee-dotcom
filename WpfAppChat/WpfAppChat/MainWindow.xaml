<Window x:Class="WpfAppChat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppChat"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel Margin="15">
        <TextBlock Text="Chatbot awarenesss" FontSize="19"/>
        <ListBox x:Name="lstChat" Height="260"/>
        <TextBox x:Name="txtMessage" Height="50" Margin="0,0,0,10"/>
        <Button Content="Send Chat" Height="30" Click="Button_Click" Margin="0,0,0,10"/>
        <Button Content="clear" Click="Button_Click_2"/>


    </StackPanel>
</Window>
